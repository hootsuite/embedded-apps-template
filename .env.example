# Hootsuite Embedded App Configuration
# Copy this file to .env and fill in your values

# Your Hootsuite App ID (obtained from the developer portal)
HOOTSUITE_APP_ID=

# Frontend development server port
FRONTEND_PORT=8080

# Backend server port
BACKEND_PORT=3001

# Backend host URL (change to your production URL before deploying)
BACKEND_HOST=http://localhost:3001

# Enable Hot Module Replacement (set to TRUE for development)
HMR_ENABLED=FALSE

# Hootsuite Dashboard URL (for CORS configuration)
HOOTSUITE_DASHBOARD_URL=https://hootsuite.com

# ngrok Configuration (for testing OAuth locally)
# Set to TRUE to enable ngrok tunnel when running npm start
NGROK_ENABLED=FALSE

# ngrok authtoken (REQUIRED when NGROK_ENABLED=TRUE)
# 1. Create a free account at: https://dashboard.ngrok.com/signup
# 2. Get your authtoken at: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
